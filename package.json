{
  "name": "realm-walker-story",
  "version": "1.0.0",
  "description": "ThreeJS TS/Node.js adventure game with three-tier compositor architecture",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/demo.ts",
    "demo": "ts-node src/demo.ts",
    "demo:import": "ts-node src/demo-import.ts",
    "demo:integrations": "ts-node src/demo-integrations.ts",
    "dev": "ts-node src/demo.ts",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "playwright:install": "playwright install chromium",
    "validate:rwmd": "ts-node scripts/validate-rwmd.ts"
  },
  "keywords": [
    "threejs",
    "game",
    "adventure",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/openai": "^2.0.53",
    "@anthropic-ai/sdk": "^0.67.0",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "ai": "^5.0.78",
    "better-sqlite3": "^12.4.1",
    "canvas": "^3.2.0",
    "openai": "^6.7.0",
    "pathfinding": "^0.4.18",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.180.0",
    "yuka": "^0.7.8",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.9.1",
    "@types/pathfinding": "^0.1.0",
    "@types/three": "^0.180.0",
    "jest": "^29.5.0",
    "playwright": "^1.56.1",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
